<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F1EA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:background="#1C2A21"
            android:padding="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Blackwood Fine Sales"
                android:textColor="#F4F1EA"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Completar registro"
                android:textColor="#C6A75E"/>
        </LinearLayout>

        <!-- CONTENIDO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:orientation="vertical">

            <!-- SEGURIDAD -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Seguridad"
                android:textSize="20sp"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Contraseña"
                android:background="@drawable/input_bg"
                android:padding="14dp"
                android:layout_marginBottom="12dp"
                android:inputType="textPassword"/>

            <EditText
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Confirmar contraseña"
                android:background="@drawable/input_bg"
                android:padding="14dp"
                android:layout_marginBottom="20dp"
                android:inputType="textPassword"/>

            <!-- MEDIOS DE PAGO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medios de pago"
                android:textSize="20sp"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="12dp"/>

            <!-- TARJETA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/input_bg"
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tarjeta crédito"
                    android:textColor="#1A1A1A"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="**** 4587 · Internacional"
                    android:textColor="#6B6B6B"/>
            </LinearLayout>

            <!-- CUENTA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/input_bg"
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cuenta bancaria"
                    android:textColor="#1A1A1A"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Banco exterior · USD"
                    android:textColor="#6B6B6B"/>
            </LinearLayout>

            <!-- BOTÓN AGREGAR -->
            <Button
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="+ Agregar medio de pago"
                android:background="@drawable/button_black_gold"
                android:textColor="#6B6B6B"
                android:layout_marginBottom="20dp"/>

            <!-- INFO -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tus medios de pago habilitan tu participación en subastas y pueden mejorar tu categoría. Puedes agregar múltiples opciones."
                android:background="@drawable/info_box"
                android:padding="14dp"
                android:textColor="#6B6B6B"
                android:layout_marginBottom="20dp"/>

            <!-- FINAL -->
            <Button
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Finalizar registro"
                android:background="@drawable/button_primary"
                android:textColor="#F4F1EA"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>